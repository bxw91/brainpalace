{
  "providers": {
    "embedding": {
      "cohere": {
        "default_api_key_env": "COHERE_API_KEY",
        "models": [
          "embed-english-v3.0",
          "embed-multilingual-v3.0"
        ],
        "needs_base_url": false
      },
      "ollama": {
        "default_api_key_env": null,
        "models": [
          "nomic-embed-text",
          "mxbai-embed-large"
        ],
        "needs_base_url": true
      },
      "openai": {
        "default_api_key_env": "OPENAI_API_KEY",
        "models": [
          "text-embedding-3-large",
          "text-embedding-3-small"
        ],
        "needs_base_url": false
      }
    },
    "reranker": {
      "ollama": {
        "default_api_key_env": null,
        "models": [
          "llama3.2:1b"
        ],
        "needs_base_url": true
      },
      "sentence-transformers": {
        "default_api_key_env": null,
        "models": [
          "cross-encoder/ms-marco-MiniLM-L-6-v2",
          "cross-encoder/ms-marco-MiniLM-L-12-v2"
        ],
        "needs_base_url": false
      }
    },
    "summarization": {
      "anthropic": {
        "default_api_key_env": "ANTHROPIC_API_KEY",
        "models": [
          "claude-haiku-4-5-20251001",
          "claude-sonnet-4-5-20250514"
        ],
        "needs_base_url": false
      },
      "gemini": {
        "default_api_key_env": "GEMINI_API_KEY",
        "models": [
          "gemini-3.1-flash-lite",
          "gemini-3.5-flash"
        ],
        "needs_base_url": false
      },
      "grok": {
        "default_api_key_env": "XAI_API_KEY",
        "models": [
          "grok-4",
          "grok-4-fast"
        ],
        "needs_base_url": true
      },
      "ollama": {
        "default_api_key_env": null,
        "models": [
          "llama4:scout",
          "mistral-small3.2",
          "qwen3-coder"
        ],
        "needs_base_url": true
      },
      "openai": {
        "default_api_key_env": "OPENAI_API_KEY",
        "models": [
          "gpt-5-mini",
          "gpt-5"
        ],
        "needs_base_url": false
      }
    }
  },
  "sections": [
    {
      "cost": "LLM",
      "fields": [
        {
          "default": "openai",
          "dotpath": "embedding.provider",
          "help": "Embedding provider. Drives the model choices, base URL, and expected API-key env var below.",
          "key": "provider",
          "label": "Provider",
          "options": [
            "cohere",
            "ollama",
            "openai"
          ],
          "secret": false,
          "widget": "enum"
        },
        {
          "default": "text-embedding-3-large",
          "dotpath": "embedding.model",
          "help": "Embedding model. Presets follow the selected provider; pick Custom\u2026 for any other model.",
          "key": "model",
          "label": "Model",
          "presets": [
            "text-embedding-3-large",
            "text-embedding-3-small",
            "embed-english-v3.0",
            "embed-multilingual-v3.0",
            "nomic-embed-text",
            "mxbai-embed-large"
          ],
          "secret": false,
          "widget": "text"
        },
        {
          "default": null,
          "dotpath": "embedding.base_url",
          "help": "Custom API endpoint (e.g. Ollama http://localhost:11434, or an OpenAI-compatible proxy). Empty = provider default.",
          "key": "base_url",
          "label": "Base url",
          "secret": false,
          "widget": "text"
        },
        {
          "default": null,
          "dotpath": "embedding.api_key_env",
          "help": "Name of the environment variable holding the API key (e.g. OPENAI_API_KEY). Empty = the provider's conventional default env var.",
          "key": "api_key_env",
          "label": "API key env var",
          "placeholder": "OPENAI_API_KEY",
          "secret": false,
          "widget": "text"
        },
        {
          "default": null,
          "dotpath": "embedding.api_key",
          "help": "Optional. A literal API key stored in config.yaml (discouraged \u2014 secrets in a file). Prefer the 'API key env var' which names an environment variable. Empty = use the env var.",
          "key": "api_key",
          "label": "API key (inline \u2014 prefer env var)",
          "secret": true,
          "widget": "text"
        },
        {
          "default": {},
          "dotpath": "embedding.params",
          "help": "Extra provider params (key/value). Passed through to the client.",
          "key": "params",
          "label": "Params",
          "secret": false,
          "widget": "dict"
