        }
      ],
      "key": "summarization",
      "label": "Summarization"
    },
    {
      "cost": "LLM",
      "fields": [
        {
          "default": false,
          "dotpath": "reranker.enabled",
          "help": "Two-stage retrieval: after the first stage (bm25/vector/hybrid) returns candidates, a local cross-encoder rescores each (query, chunk) pair and reorders by relevance. No API cost (local model); adds a little query latency. Default: off.",
          "key": "enabled",
          "label": "Enabled",
          "secret": false,
          "widget": "toggle"
        },
        {
          "default": "sentence-transformers",
          "dotpath": "reranker.provider",
          "help": "sentence-transformers = local cross-encoder, no API cost, no base URL (recommended). ollama = prompt-based scoring served by Ollama; works with any chat model but is slower and needs a base URL.",
          "key": "provider",
          "label": "Provider",
          "options": [
            "ollama",
            "sentence-transformers"
          ],
          "secret": false,
          "widget": "enum"
        },
        {
          "default": "cross-encoder/ms-marco-MiniLM-L-6-v2",
          "dotpath": "reranker.model",
          "help": "sentence-transformers: a cross-encoder model (empty = built-in default cross-encoder/ms-marco-MiniLM-L-6-v2). ollama: any chat model (e.g. llama3.2:1b) used for prompt-based relevance scoring.",
          "key": "model",
          "label": "Model",
          "presets": [
            "cross-encoder/ms-marco-MiniLM-L-6-v2",
            "cross-encoder/ms-marco-MiniLM-L-12-v2",
            "llama3.2:1b"
          ],
          "secret": false,
          "widget": "text"
        },
        {
          "default": null,
          "dotpath": "reranker.base_url",
          "help": "Custom API endpoint (e.g. Ollama http://localhost:11434, or an OpenAI-compatible proxy). Empty = provider default.",
          "key": "base_url",
          "label": "Base url",
          "secret": false,
          "widget": "text"
        },
        {
          "default": {},
          "dotpath": "reranker.params",
          "help": "Extra reranker params (key/value). Passed through to the client.",
          "key": "params",
          "label": "Params",
          "secret": false,
          "widget": "dict"
        }
      ],
      "key": "reranker",
      "label": "Reranker"
    },
    {
      "cost": "free",
      "fields": [
        {
          "default": false,
          "dotpath": "bm25.detect",
          "help": "Detect each document's language individually (py3langid). When off, every document uses the default language below. Default: off.",
          "key": "detect",
          "label": "Auto-detect language (per document)",
          "secret": false,
          "widget": "toggle"
        },
        {
          "default": 0.6,
          "dotpath": "bm25.detect_min_confidence",
          "help": "Below this confidence, a document falls back to the default language. Only used when auto-detect is on. Default: 0.6.",
          "key": "detect_min_confidence",
          "label": "Auto-detect min confidence",
          "secret": false,
          "visible_when": {
            "equals": "true",
            "field": "bm25.detect"
          },
          "widget": "text"
        },
        {
          "default": "stem",
          "dotpath": "bm25.engine",
          "key": "engine",
          "label": "Engine",
          "options": [
            "lemma",
            "stem"
          ],
          "secret": false,
          "widget": "enum"
        },
        {
          "default": "en",
          "dotpath": "bm25.language",
          "help": "Tokenizer language used as the default, and the fallback when auto-detect is off or below the confidence threshold. Default: en.",
          "key": "language",
          "label": "Default / fallback language",
          "secret": false,
          "widget": "text"
        }
      ],
      "key": "bm25",
      "label": "BM25"
    },
    {
      "cost": "LLM/subagent",
      "description": "The knowledge graph (entities + relationships) that powers graph and multi query modes.",
      "fields": [
        {
          "default": true,
          "dotpath": "graphrag.enabled",
          "help": "Master switch for the knowledge graph (entities + relationships mined from code and docs). Powers graph/multi query modes.",
          "key": "enabled",
          "label": "Enabled",
          "secret": false,
          "widget": "toggle"
        },
        {
          "default": true,
          "dotpath": "graphrag.use_code_metadata",
          "help": "Enrich graph nodes with code-structure metadata (symbols, signatures) for richer graph queries. Default: on.",
          "key": "use_code_metadata",
          "label": "Use code metadata",
          "secret": false,
          "widget": "toggle"
        },
        {
          "default": "sqlite",
          "dotpath": "graphrag.store_type",
          "help": "simple = in-memory graph, rebuilt on every server start, with NO temporal (versioned-over-time) edges \u2014 lightest, ephemeral. sqlite = persistent on-disk graph that supports the temporal knowledge graph (edges versioned over time). Default and recommended: sqlite.",
          "key": "store_type",
          "label": "Store type",
          "options": [
            "simple",
            "sqlite"
          ],
          "secret": false,
          "widget": "enum"
        }
      ],
      "key": "graphrag",
      "label": "GraphRAG"
    },
    {
      "cost": "free",
      "description": "Language-server (LSP) cross-references for the code graph \u2014 exact cross-file `calls` edges. auto = enable a language when its server binary (e.g. pyright) is detected; on = force; off = disable. AST-only intra-file calls work regardless.",
      "fields": [
        {
          "default": "auto",
          "dotpath": "graph_indexing.lsp.mode",
          "help": "auto = enable an on-toggled language when its server binary is found on PATH/venv (recommended); on = force on-toggled languages; off = disable LSP. AST intra-file calls are unaffected.",
          "key": "mode",
          "label": "LSP mode",
          "options": [
            "auto",
            "off",
            "on"
          ],
          "secret": false,
          "widget": "enum"
        },
        {
          "default": true,
          "dotpath": "graph_indexing.lsp.python",
          "help": "Use a Python language server for exact cross-file calls. auto mode needs pyright/pyright-langserver installed.",
          "key": "python",
          "label": "Python (pyright)",
          "secret": false,
          "widget": "toggle"
        },
        {
          "default": true,
          "dotpath": "graph_indexing.lsp.typescript",
          "help": "Use the TypeScript language server for exact cross-file calls. auto mode needs typescript-language-server installed.",
          "key": "typescript",
          "label": "TypeScript/JS",
          "secret": false,
          "widget": "toggle"
        }
      ],
      "key": "graph_indexing",
      "label": "Graph Indexing : LSP"
    },
    {
      "cost": "free",
      "description": "Aggregation query mode that sums typed numeric records extracted from sessions. Powers the compute query mode.",
      "fields": [
        {
          "default": 0.7,
          "dotpath": "compute.min_confidence",
          "key": "min_confidence",
          "label": "Min confidence",
          "secret": false,
          "widget": "text"
        }
      ],
      "key": "compute",
      "label": "Compute Query"
    },
