      "key": "storage",
      "label": "Storage"
    },
    {
      "cost": "free",
      "description": "Large-file re-embed guards and which paths are skipped when indexing. exclude_patterns are globs never indexed.",
      "fields": [
        {
          "default": 200,
          "dotpath": "indexing.big_file_chunks",
          "key": "big_file_chunks",
          "label": "Big file chunks",
          "secret": false,
          "widget": "int"
        },
        {
          "default": [
            "**/node_modules/**",
            "**/__pycache__/**",
            "**/.venv/**",
            "**/venv/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/target/**",
            "**/.next/**",
            "**/.nuxt/**",
